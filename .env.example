# TeamFlow — ortam değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyası .gitignore'da — GitHub'a yüklenmez.

# Groq API anahtarı uygulama içi Ayarlar'dan girilir (buraya yazmayın).

# Bulut senkronu (Supabase) — isteğe bağlı
# Kurulum: supabase/README.md
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
